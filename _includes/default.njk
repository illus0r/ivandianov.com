<!doctype html>
<html class='{{page.data.class}}'>

<head>
    <meta http-equiv="Content-Type" content="text/html; charset=UTF-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge,chrome=1" />
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{{ title }} · Ivan Dianov</title>
    <link rel="stylesheet" href="/styles.css" />
    <!-- FIXME check if it is needed -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.16.2/dist/katex.css">
    {% include "favicon.njk" %}
    {% include "metrika.njk" %}
</head>
<body{#  class="lang-{{ lang }}{% if page.collection %} type-{{ page.collection }}{% else %}{% if depth > 0 %} page-{{ path | join: '-' }}{% else %} page-front{% endif %}{% endif %}{% if page.class %} {{ page.class }}{% endif %}" #}>

    {% include 'header.njk' %}
    <main role="main" class="wrap prose">
        {{ content  | safe}}
    </main>

    {% include "footer.njk" %}

    <script src="/assets/js/prism.js" data-manual></script>
    <script src="/assets/js/prism-clike.js"></script>
    <script src="/assets/js/prism-c.js"></script>
    <script src="/assets/js/prism-glsl.js"></script>
    <script src="/assets/js/dance-dance.js" type='module'></script>
    <script src="/assets/js/glsl-preview.js"></script>
    <script>
    document.querySelectorAll('pre:not(.glsl-editor-pre):not(.glsl-errors)').forEach(pre => {
      const btn = document.createElement('button');
      btn.className = 'copy-btn';
      btn.textContent = 'copy';
      btn.onclick = () => {
        navigator.clipboard.writeText(pre.querySelector('code').innerText);
        btn.textContent = 'copied';
        btn.classList.add('copied');
        setTimeout(() => { btn.textContent = 'copy'; btn.classList.remove('copied'); }, 1500);
      };
      pre.appendChild(btn);
    });
    </script>
    </body>

</html>
